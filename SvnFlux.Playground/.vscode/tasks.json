{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build Playground",
      "type": "process",
      "command": "dotnet",
      "args": ["build", "${workspaceFolder}/SvnFlux.Playground.csproj", "--configuration", "Debug", "--nologo"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
